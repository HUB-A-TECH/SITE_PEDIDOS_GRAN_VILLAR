# PostgreSQL — troque a URL conforme onde o banco roda
DATABASE_URL="postgresql://granvillar:granvillar@localhost:5432/granvillar?schema=public"

# JWT — gere um segredo forte (ex.: openssl rand -hex 32)
JWT_SECRET="troque-por-um-segredo-forte-e-aleatorio"
JWT_EXPIRES_IN="8h"

# Servidor
PORT=3333
NODE_ENV=development

# Origem do frontend (CORS)
FRONTEND_ORIGIN="http://localhost:5173"

# Cookie seguro (true apenas em produção com HTTPS)
COOKIE_SECURE=false
